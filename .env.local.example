# Copy this file to .env.local and fill in your Supabase credentials.
# Get these from: https://app.supabase.com → Project Settings → API
#
# Auth (Google + magic link) needs NEXT_PUBLIC_SUPABASE_URL + ANON_KEY on Vercel too.
# Fuel Tracker API + counters need SUPABASE_SERVICE_ROLE_KEY (server only).

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# Anon / publishable key — safe for the browser (RLS-enforced)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...your_anon_key_here
# Service role — server-only (Route Handlers). Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...your_service_role_key_here

# Contact form (Resend) — server-only. Domain must be verified in Resend.
# From stays hello@… publicly; To is your real inbox (forward optional).
RESEND_API_KEY=re_xxxxxxxx
CONTACT_FROM_EMAIL=NexusDigitalLabs <hello@nexusdigitallabs.dev>
CONTACT_TO_EMAIL=you@example.com
